# Copy to .env and fill in values

# PostgreSQL connection (shared by apps/web and apps/fetcher via packages/db)
DATABASE_URL="postgresql://hotai:hotai@localhost:5432/hotai?schema=public"

# Next.js site
NEXT_PUBLIC_SITE_URL="https://hotai.example.com"
NEXT_PUBLIC_SITE_NAME="Hot AI"

# Fetcher schedule (cron format, server local time). Default: every hour at :07
FETCHER_CRON="7 * * * *"

# Scoring tunables
SCORING_HALFLIFE_HOURS="24"
SCORING_KEYWORDS="GPT,Claude,Gemini,LLM,Llama,Mistral,DeepSeek,Qwen,OpenAI,Anthropic,Sora,o1,o3"

# Optional: trigger web ISR revalidation from fetcher after each cycle
REVALIDATE_SECRET=""
REVALIDATE_URL="http://localhost:3000/api/revalidate"

# User-Agent for scraping
FETCHER_USER_AGENT="HotAI-Bot/0.1 (+https://hotai.example.com)"

# Hard retention: articles older than N days are deleted at the start of each fetch cycle.
# Project policy is 2 weeks — the site is about "today's hot", not archive.
# Digest rows are kept indefinitely (small and useful for history).
ARTICLE_RETENTION_DAYS="14"

# ===== AI enrichment (optional) =====
# When ANTHROPIC_API_KEY is set:
#   - fetcher auto-summarises new articles (LLM_MODEL_FAST)
#   - daily digest gets generated (LLM_MODEL_SMART)
#   - /api/ask streaming endpoint becomes available
# Without a key, AI features degrade silently — the site keeps working
# with raw titles + source summaries.
ANTHROPIC_API_KEY=""

# === Point at a relay/proxy ===
# The code uses the official @anthropic-ai/sdk, which speaks the
# /v1/messages protocol. Any relay that speaks the same protocol works —
# just set ANTHROPIC_BASE_URL to the relay's root (no trailing /v1).
# Examples:
#   https://api.anthropic.com          (default if unset — direct)
#   https://api.your-relay.example     (a self-hosted Anthropic-compatible proxy)
ANTHROPIC_BASE_URL=""

# === Model IDs ===
# Whatever model strings your endpoint accepts. Defaults assume Anthropic-direct;
# override when the relay routes to different models / aliases.
#   LLM_MODEL_FAST  = per-article enrichment (cheap, runs many times per cycle)
#   LLM_MODEL_SMART = daily digest synthesis (runs ~once per day)
LLM_MODEL_FAST="claude-haiku-4-5"
LLM_MODEL_SMART="claude-sonnet-4-6"

# === Relay quirks ===
# Anthropic's prompt cache (`cache_control: ephemeral`) cuts cost on batch
# enrichment, but many relays don't implement it and will 400. Set to "false"
# to strip cache_control from every request.
AI_PROMPT_CACHE="true"

# How many articles to AI-enrich per fetch cycle (highest-scored first).
AI_ENRICH_PER_RUN="30"
# Parallel requests for enrichment. 4 is a safe default; lower it if your relay rate-limits.
AI_CONCURRENCY="4"
# Set to "false" to skip daily digest generation but keep per-article enrichment.
AI_DIGEST_ENABLED="true"
